      <aliases enabled='yes' />
      <column caption='Account Activity Type' datatype='string' name='[Calculation_0119576338829312]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_non_transacting_account (novabank_accounts_flat.csv)]&#13;&#10;THEN &quot;Non-Transacting Account&quot;&#13;&#10;&#13;&#10;ELSE &quot;Transacting Account&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0224854108131328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Exe Lifecycle Stage' datatype='string' name='[Calculation_0224854110793729]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_non_transacting_customer] = True&#13;&#10;THEN &quot;Never Transacted&quot;&#13;&#10;&#13;&#10;ELSEIF [lifecycle_stage] = &quot;Active&quot;&#13;&#10;THEN &quot;Active&quot;&#13;&#10;&#13;&#10;ELSEIF [lifecycle_stage] = &quot;New&quot;&#13;&#10;THEN &quot;New&quot;&#13;&#10;&#13;&#10;ELSEIF [lifecycle_stage] = &quot;Declining&quot;&#13;&#10;THEN &quot;Declining&quot;&#13;&#10;&#13;&#10;ELSEIF [lifecycle_stage] = &quot;Dormant&quot;&#13;&#10;THEN &quot;Dormant&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Executive LifeCycle STage' datatype='string' name='[Calculation_0224854119067650]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_non_transacting_customer] THEN&#13;&#10;    &quot;Never Transacted&quot;&#13;&#10;&#13;&#10;ELSEIF ISNULL([lifecycle_stage]) THEN&#13;&#10;    &quot;Unknown&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    [lifecycle_stage]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Non-Transacting %' datatype='real' name='[Calculation_0224854213115907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [is_non_transacting_customer] THEN [customer_id] END&#13;&#10;)  / COUNTD([customer_id])' />
      </column>
      <column caption='Low Engagement Customers %' datatype='real' name='[Calculation_0224854214881284]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [rfm_segment] = &quot;Low Value&quot; THEN [customer_id]&#13;&#10;ELSEIF [rfm_segment] = &quot;At Risk&quot; THEN [customer_id]&#13;&#10;ELSEIF  [rfm_segment] = &quot;Dormant&quot; THEN [customer_id]&#13;&#10;END&#13;&#10;) / COUNTD([customer_id])' />
      </column>
      <column caption='Declining Customers' datatype='integer' name='[Calculation_0224854217289734]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [lifecycle_stage] = &quot;Declining&quot;&#13;&#10;THEN [customer_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Customer Activity Type' datatype='string' name='[Calculation_0224854218399751]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_non_transacting_customer]&#13;&#10;THEN &quot;Non-Transacting&quot;&#13;&#10;ELSE &quot;Transacting&quot;&#13;&#10;END' />
      </column>
      <column caption='DIgi-Trans %' datatype='real' name='[Calculation_0232001286836224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [is_online] = TRUE and [transaction_status] = &quot;Successful&quot;&#13;&#10; Then [transaction_id] END&#13;&#10;)/ COUNTD(&#13;&#10;    IF [transaction_status] = &quot;Successful&quot;&#13;&#10; Then [transaction_id] END&#13;&#10;)' />
      </column>
      <column caption='Transaction Hour' datatype='integer' name='[Calculation_0232001297436674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;,[transaction_datetime])' />
      </column>
      <column caption='Transacting Accounts %' datatype='real' name='[Calculation_0232001314971651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.537' />
      </column>
      <column caption='Non-Transacting Accounts %' datatype='real' name='[Calculation_0232001316057092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.5365' />
      </column>
      <column caption='KPI 1 — Month 0 Activation Rate' datatype='real' name='[Calculation_0912049181278208]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.40150000' />
      </column>
      <column caption='KPI 2 — Best Cohort Retention' datatype='real' name='[Calculation_0912049182015489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.91' />
      </column>
      <column caption='KPI 3 — 2023 Cohort Deterioration' datatype='integer' name='[Calculation_0912049185026050]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='2023' />
      </column>
      <column caption='Total Transacting Customers' datatype='integer' name='[Calculation_0936787563356160]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id_x])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0936787563704321]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='5000' />
      </column>
      <column caption='Total Active Customers' datatype='integer' name='[Calculation_0936787563954178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [lifecycle_stage] == &quot;Active&quot; THEN [customer_id_x] END)' />
      </column>
      <column caption='Retantion Rate' datatype='real' name='[Calculation_0936787564462083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0936787563954178]/(5000 - COUNTD(IF [lifecycle_stage] ==&quot;New&quot; THEN [customer_id_x] END))' />
      </column>
      <column caption='Transaction Sucessrate' datatype='real' name='[Calculation_0936787565744132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [transaction_status] == &quot;Successful&quot; THEN [customer_id_x] END)/ COUNTD([transaction_id])' />
      </column>
      <column caption='Portfolio Inflow' datatype='real' name='[Calculation_0936787568095237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum({ FIXED [customer_id_x] :&#13;&#10;MAX ([total_inflow_amount])&#13;&#10;})' />
      </column>
      <column caption='Net CashFLow' datatype='real' name='[Calculation_0936787568996359]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0936787568095237] - [Portfolio Inflow (copy)_0936787568709638]' />
      </column>
      <column caption='Withdrawal Rate' datatype='real' name='[DIgi-Trans % (copy)_0232001288904705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [is_withdrawal] = TRUE and [transaction_status] = &quot;Successful&quot;&#13;&#10; Then [transaction_id] END&#13;&#10;)/ COUNTD(&#13;&#10;    IF [transaction_status] = &quot;Successful&quot;&#13;&#10; Then [transaction_id] END&#13;&#10;)' />
      </column>
      <column caption='Portfolio Outflow' datatype='real' name='[Portfolio Inflow (copy)_0936787568709638]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum({ FIXED [customer_id_x] :&#13;&#10;MAX ([total_outflow_amount])&#13;&#10;})' />
      </column>
      <column caption='novabank_accounts_flat.csv' datatype='table' name='[__tableau_internal_object_id__].[novabank_accounts_flat.csv_BBFA038FF56A4C42B4624079F8AE6E4D]' role='measure' type='quantitative' />
