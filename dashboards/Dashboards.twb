    <worksheet name='KPI - Retention Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='novabank_flat' name='federated.0pmkvvu0vxlzjg1121hlv11tvan9' />
          </datasources>
          <datasource-dependencies datasource='federated.0pmkvvu0vxlzjg1121hlv11tvan9'>
            <column caption='Total Active Customers' datatype='integer' name='[Calculation_0936787563954178]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [lifecycle_stage] == &quot;Active&quot; THEN [customer_id_x] END)' />
            </column>
            <column caption='Retantion Rate' datatype='real' name='[Calculation_0936787564462083]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0936787563954178]/(5000 - COUNTD(IF [lifecycle_stage] ==&quot;New&quot; THEN [customer_id_x] END))' />
            </column>
            <column aggregation='CountD' caption='Customer Id X' datatype='string' default-role='measure' default-type='quantitative' name='[customer_id_x]' role='dimension' type='nominal' />
            <column caption='Lifecycle Stage' datatype='string' name='[lifecycle_stage]' role='dimension' type='nominal' />
